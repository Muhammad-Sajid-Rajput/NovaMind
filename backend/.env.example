# NovaMind — .env.example — Phase 4

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173

# ─── Gemini AI — Multi-Key Rotation ──────────────────────────────────────────
# Add up to 3 keys for round-robin rotation (3x daily request quota).
# Get keys at: https://aistudio.google.com/apikey
#
# With 3 keys on the free tier (gemini-2.5-flash = 500 req/day each):
#   1 key  =  500 requests/day
#   3 keys = 1500 requests/day
#
# At least GEMINI_API_KEY_1 is required. _2 and _3 are optional.
GEMINI_API_KEY_1=your_first_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here
GEMINI_API_KEY_3=your_third_gemini_api_key_here

# ─── Resend Email ─────────────────────────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
# From address — must be a verified sender in Resend (use onboarding@resend.dev for testing)
RESEND_FROM=NovaMind <onboarding@resend.dev>

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/novamind?retryWrites=true&w=majority

# ─── Authentication — Dual Token ─────────────────────────────────────────────
# JWT_ACCESS_SECRET  → signs short-lived access tokens (15 min)
# JWT_REFRESH_SECRET → signs long-lived refresh tokens (30 days, stored in httpOnly cookie)
# These MUST be different secrets. Both must be at least 32 characters.
#
# Generate secure secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_super_secret_access_key_minimum_32_chars_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_chars_change_this

# ─── Cloudinary (Phase 3) ─────────────────────────────────────────────────────
# Get your credentials at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
# Used by BullMQ for background document ingestion jobs.
# Recommended: Upstash Redis (free tier, TLS, works identically local & production)
# Get your URL at: https://console.upstash.com
# Format: rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ─── Pinecone Vector DB (Phase 4) ─────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=novamind

# ─── Tavily Web Search (Phase 4) ──────────────────────────────────────────────
TAVILY_API_KEY=

# ─── Observability (Phase 5) ──────────────────────────────────────────────────
# Secures the /metrics endpoint from unauthorized Prometheus scraping.
# Must be at least 8 characters. Passed via header: X-Metrics-Secret: <value>
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
METRICS_SECRET=your_secure_metrics_secret_here
